# Copy to feedback-poller.env on the Jarvis server (chmod 600, do NOT commit).
# The cron wrapper sources this before running jarvis-feedback-poller.py.

# Dev API while testing; switch to https://brookeslist-api.dabrewer.dev for prod.
BROOKESLIST_API=https://brookeslist-api-dev.dabrewer.dev

# Must match the Worker secret: `wrangler secret put JARVIS_INGEST_TOKEN [--env dev]`
JARVIS_INGEST_TOKEN=paste-the-token-here

# Jarvis's Gmail (the "From") + an app password (same account Jarvis emails from)
SMTP_USER=serveremail.jarvis@gmail.com
SMTP_PASS=gmail-app-password
NOTIFY_TO=myemailisdanmail@gmail.com

# Optional overrides
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# FROM_NAME=Jarvis
